      "entries": [
        "A burst of positive energy leaps out from around you, disrupting shadows and evil spirits in the area. Incorporeal creatures, such as wraiths, ghosts, or shadows automatically take {@damage 5d6} radiant damage. If any of this spell’s area intersects with an area of darkness created by a spell of 3rd level or lower, the spell that created the darkness is dispelled."
      ],
      "entriesHigherLevel": [
        {
          "name": "At Higher Levels",
          "entries": [
            "When you cast this spell using a slot of 4th level or higher, the damage increases by {@dice 1d6} for each slot level above 3rd."
          ]
        }
